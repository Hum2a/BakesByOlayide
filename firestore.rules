rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isStaff() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isDeveloper', false) == true
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin'
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'developer'
        );
    }

    // Server-only writes (Admin SDK). Staff read for admin Outbox UI.
    match /emailOutbox/{entryId} {
      allow read: if isStaff();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if request.auth != null && !document.matches('emailOutbox/**');
    }
  }
}
