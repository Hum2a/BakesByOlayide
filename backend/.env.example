# Copy to ../.env at repository root (server.js loads dotenv from cwd) or set in Render.
PORT=5000
NODE_ENV=development

# Zoho SMTP
ZOHO_SMTP_HOST=
ZOHO_SMTP_PORT=587
ZOHO_ORDERS_USER=
ZOHO_ORDERS_PASS=
ZOHO_ENQUIRIES_USER=
ZOHO_ENQUIRIES_PASS=
ZOHO_MARKETING_USER=
ZOHO_MARKETING_PASS=

# New checkout order: BCC on the shop copy (sent from Orders Zoho to the orders inbox).
# Unset = bakedbyolayide@gmail.com. Set empty to disable. Comma-separated for multiple.
EMAIL_NEW_ORDER_NOTIFY_TO=bakedbyolayide@gmail.com

# New contact form + new product review: BCC on staff emails (Enquiries Zoho → enquiries inbox).
# Same defaults as above; separate vars so you can disable one channel only.
EMAIL_NEW_CONTACT_ENQUIRY_NOTIFY_TO=bakedbyolayide@gmail.com
EMAIL_NEW_REVIEW_NOTIFY_TO=bakedbyolayide@gmail.com

# Staff BCC (comma or semicolon). Hidden from the customer; traceability / notifications.
# Order confirmations (admin), checkout basket enquiry (shop + customer emails).
# Example: developers@bakesbyolayide.co.uk,orders@bakesbyolayide.co.uk
EMAIL_NOTIFY_BCC_ORDERS=
# Admin enquiry replies (contact form pipeline).
EMAIL_NOTIFY_BCC_ENQUIRIES=

# Firebase Admin (server-side)
FIREBASE_TYPE=
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=
FIREBASE_AUTH_URI=
FIREBASE_TOKEN_URI=
FIREBASE_AUTH_PROVIDER_CERT_URL=
FIREBASE_CLIENT_CERT_URL=
