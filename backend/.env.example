# Copy to ../.env at repository root (server.js loads dotenv from cwd) or set in Render.
PORT=5000
NODE_ENV=development

# Zoho SMTP
ZOHO_SMTP_HOST=
ZOHO_SMTP_PORT=587
ZOHO_ORDERS_USER=
ZOHO_ORDERS_PASS=
ZOHO_ENQUIRIES_USER=
ZOHO_ENQUIRIES_PASS=
ZOHO_MARKETING_USER=
ZOHO_MARKETING_PASS=

# Firebase Admin (server-side)
FIREBASE_TYPE=
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=
FIREBASE_AUTH_URI=
FIREBASE_TOKEN_URI=
FIREBASE_AUTH_PROVIDER_CERT_URL=
FIREBASE_CLIENT_CERT_URL=
