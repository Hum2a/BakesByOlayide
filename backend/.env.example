# Local: server.js loads BOTH ../.env (repo root) and this file (backend/.env), so either location works.
# Production: set these in Render, Fly.io secrets, etc. Do not commit real keys.
#
# Fly.io: trial then paid (not a permanent $0 tier for new signups). Good for Zoho SMTP if you accept ongoing cost.
# From repo root: `fly secrets set KEY=value ...` (same names as below). Dockerfile sets REACT_APP_API_RELATIVE=1
# so the SPA calls /api on the same host. https://fly.io/docs/reference/secrets/ · https://fly.io/pricing
#
# Render free web services: outbound SMTP to ports 25, 465, 587 is blocked — Zoho will show "Connection timeout".
# Upgrade to a paid instance or use an email provider’s HTTPS API. See:
# https://render.com/changelog/free-web-services-will-no-longer-allow-outbound-traffic-to-smtp-ports
# HTTP port for Express (npm run server). CRA dev is pinned to 3000 via craco.config.js so PORT=5000 here
# does not collide with npm start. Optional override: API_PORT=5001 if 5000 is stuck (update proxy + REACT_APP_API_BASE_URL).
PORT=5000
NODE_ENV=development

# Log each /api request as [http] METHOD path status ms. Default: on when NODE_ENV=production, off otherwise.
# HTTP_LOG=true
# HTTP_LOG=false

# Zoho SMTP
# Port 587 = STARTTLS (recommended). Port 465 = SSL. Do not set ZOHO_SMTP_SECURE unless you must override.
# ZOHO_SMTP_SECURE=true   # force implicit SSL (use with port 465)
# ZOHO_SMTP_SECURE=false  # force STARTTLS (use with port 587)
ZOHO_SMTP_HOST=
ZOHO_SMTP_PORT=587
ZOHO_ORDERS_USER=
ZOHO_ORDERS_PASS=
ZOHO_ENQUIRIES_USER=
ZOHO_ENQUIRIES_PASS=
ZOHO_MARKETING_USER=
ZOHO_MARKETING_PASS=

# Basket enquiry (shop email): extra addresses in CC on the copy to ZOHO_ORDERS_USER, plus bakedbyolayide@gmail.com
# is always CC’d unless it is the orders inbox. Unset = only the default Gmail. Set empty = still CC Gmail; no extras.
# Comma-separated for multiple extras.
EMAIL_NEW_ORDER_NOTIFY_TO=bakedbyolayide@gmail.com

# New contact form + admin enquiry replies to customers + new product review: BCC notify list (Enquiries channel).
# Same defaults as above; separate vars so you can disable one channel only.
EMAIL_NEW_CONTACT_ENQUIRY_NOTIFY_TO=bakedbyolayide@gmail.com
EMAIL_NEW_REVIEW_NOTIFY_TO=bakedbyolayide@gmail.com

# Staff BCC (comma or semicolon). Hidden from the customer; traceability / notifications.
# Order confirmations (admin), checkout basket enquiry (shop + customer emails).
# Example: developers@bakesbyolayide.co.uk,orders@bakesbyolayide.co.uk
EMAIL_NOTIFY_BCC_ORDERS=
# Admin enquiry replies (contact form pipeline).
EMAIL_NOTIFY_BCC_ENQUIRIES=

# Firebase Admin (server-side)
FIREBASE_TYPE=
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=
FIREBASE_AUTH_URI=
FIREBASE_TOKEN_URI=
FIREBASE_AUTH_PROVIDER_CERT_URL=
FIREBASE_CLIENT_CERT_URL=
